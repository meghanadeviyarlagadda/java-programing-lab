class MyException extends Exception {
    MyException(String msg) {
        super(msg);
    }
}

public class TestException {
    public static void main(String[] args) {
        try {
            int age = 15;
            if (age < 18)
                throw new MyException("Not eligible");
        } catch (MyException e) {
            System.out.println(e.getMessage());
        }
    }
}
