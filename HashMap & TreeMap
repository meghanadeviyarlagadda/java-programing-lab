import java.util.*;

class MapDemo {
    public static void main(String[] args){
        HashMap<Integer,String> hm=new HashMap<>();
        hm.put(2,"B");
        hm.put(1,"A");

        TreeMap<Integer,String> tm=new TreeMap<>(hm);

        System.out.println(hm);
        System.out.println(tm);
    }
}
